{
  "_说明": "LAK-Agent 开发环境配置 — feature/* / dev 分支使用。权限宽松，允许快速迭代。",

  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(mvn *)",
      "Bash(java *)",
      "Bash(javac *)",
      "Bash(docker *)",
      "Bash(curl *)",
      "Bash(mkdir *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(rm *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(head *)",
      "Bash(tail *)"
    ],
    "deny": [
      "Bash(rm -rf / *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(git push *main*)",
      "Bash(git push *master*)",
      "Bash(git push --force *)"
    ]
  },

  "_dev_notes": [
    "dev 分支：允许跳过权限确认（快速迭代）",
    "允许 grep/sed/cp/mv 等常用开发命令",
    "仍禁止 push main/master（防误操作）",
    "仍禁止递归删除根目录和关机命令"
  ]
}
