# =============================================================================
# LAK-Agent 开发环境变量
# 复制此文件为 .env 后修改实际值
# =============================================================================

# Docker Compose 工程名（必须唯一，避免与 EICS 工程的数据卷冲突）
COMPOSE_PROJECT_NAME=lak

# MySQL
MYSQL_ROOT_PASSWORD=root_dev_2026
MYSQL_DATABASE=lak_ai_platform
MYSQL_USER=lak_user
MYSQL_PASSWORD=lak_dev_2026
MYSQL_PORT=3307

# Redis
REDIS_PORT=6380

# Qdrant
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334

# MinIO（避开 EICS 平台端口 9000/9002）
MINIO_API_PORT=9004
MINIO_CONSOLE_PORT=9005
MINIO_ROOT_USER=lak_admin
MINIO_ROOT_PASSWORD=lak_dev_2026
